---
// Global full-text search over docs + blog. Reads /search.json (generated
// by src/pages/search.json.ts) and filters client-side — small corpus, so
// no search index dependency, and it works in `astro dev` too.
---

<button
  id="search-open"
  class="search-open"
  type="button"
  aria-label="Search docs and blog"
  aria-keyshortcuts="Control+K Meta+K"
>
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
    <path
      d="m20 20-3.5-3.5"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"></path>
  </svg>
  <span class="lbl">Search</span>
  <kbd class="kbd">⌘K</kbd>
</button>

<dialog id="search-dialog" class="search-dialog" aria-label="Search docs and blog">
  <div class="search-inner">
    <div class="search-bar">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
        <path
          d="m20 20-3.5-3.5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
      <input
        id="search-q"
        type="search"
        placeholder="Search docs and blog…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search query"
      />
      <button type="button" id="search-close" class="search-close">Esc</button>
    </div>
    <div id="search-out" class="search-out">
      <p class="search-hint">Type to search the docs and blog.</p>
    </div>
  </div>
</dialog>

<script>
  const dlg = document.getElementById('search-dialog') as HTMLDialogElement;
  const openBtn = document.getElementById('search-open');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-q') as HTMLInputElement;
  const out = document.getElementById('search-out') as HTMLElement;

  type Item = {
    kind: string;
    section: string;
    title: string;
    url: string;
    tags: string[];
    text: string;
  };

  let index: Item[] | null = null;
  let results: Item[] = [];
  let cursor = -1;

  async function ensureIndex() {
    if (index) return;
    try {
      const res = await fetch('/search.json');
      index = await res.json();
    } catch {
      index = [];
    }
  }

  function esc(s: string) {
    return s.replace(
      /[&<>"]/g,
      (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] as string,
    );
  }

  function highlight(s: string, tokens: string[]) {
    let html = esc(s);
    for (const t of tokens) {
      const re = new RegExp('(' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'ig');
      html = html.replace(re, '<mark>$1</mark>');
    }
    return html;
  }

  function snippet(text: string, tokens: string[]) {
    const lower = text.toLowerCase();
    let pos = -1;
    for (const t of tokens) {
      const i = lower.indexOf(t);
      if (i >= 0 && (pos < 0 || i < pos)) pos = i;
    }
    if (pos < 0) return highlight(text.slice(0, 120), tokens);
    const start = Math.max(0, pos - 40);
    const end = Math.min(text.length, pos + 110);
    const s = (start > 0 ? '…' : '') + text.slice(start, end) + (end < text.length ? '…' : '');
    return highlight(s, tokens);
  }

  function run(q: string) {
    const tokens = q.toLowerCase().split(/\s+/).filter(Boolean);
    if (!tokens.length || !index) {
      results = [];
      render(q, tokens);
      return;
    }
    const scored: { it: Item; score: number }[] = [];
    for (const it of index) {
      const title = it.title.toLowerCase();
      const tags = it.tags.join(' ').toLowerCase();
      const text = it.text.toLowerCase();
      const hay = `${title} ${tags} ${text}`;
      if (!tokens.every((t) => hay.includes(t))) continue;
      let score = 0;
      for (const t of tokens) {
        if (title.includes(t)) score += 10;
        if (title.startsWith(t)) score += 5;
        if (tags.includes(t)) score += 6;
        if (text.includes(t)) score += 2;
      }
      scored.push({ it, score });
    }
    scored.sort((a, b) => b.score - a.score);
    results = scored.slice(0, 20).map((s) => s.it);
    render(q, tokens);
  }

  function render(q: string, tokens: string[]) {
    cursor = -1;
    if (!q) {
      out.innerHTML = '<p class="search-hint">Type to search the docs and blog.</p>';
      return;
    }
    if (!results.length) {
      out.innerHTML = `<p class="search-hint">No matches for “${esc(q)}”.</p>`;
      return;
    }
    out.innerHTML = results
      .map(
        (it, i) => `
          <a class="search-item" href="${it.url}" role="option" data-i="${i}">
            <span class="search-kind">${esc(it.section)}</span>
            <span class="search-title">${highlight(it.title, tokens)}</span>
            <span class="search-snip">${snippet(it.text, tokens)}</span>
          </a>`,
      )
      .join('');
  }

  function open() {
    ensureIndex().then(() => {
      if (!dlg.open) dlg.showModal();
      input.focus();
      input.select();
    });
  }

  openBtn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', () => dlg.close());
  input?.addEventListener('input', () => run(input.value.trim()));

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      open();
    } else if (
      e.key === '/' &&
      !dlg.open &&
      !/^(input|textarea|select)$/i.test(document.activeElement?.tagName ?? '')
    ) {
      e.preventDefault();
      open();
    }
  });

  dlg?.addEventListener('keydown', (e) => {
    const items = Array.from(out.querySelectorAll<HTMLElement>('.search-item'));
    if (!items.length) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      cursor = Math.min(items.length - 1, cursor + 1);
      items[cursor].focus();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      cursor = Math.max(0, cursor - 1);
      items[cursor].focus();
    }
  });

  // click on the backdrop area closes
  dlg?.addEventListener('click', (e) => {
    if (e.target === dlg) dlg.close();
  });

  dlg?.addEventListener('close', () => {
    input.value = '';
    render('', []);
  });
</script>

<style>
  .search-open {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    font: inherit;
    font-size: 0.85rem;
    color: var(--text-muted);
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: 999px;
    cursor: pointer;
    transition:
      border-color 150ms ease,
      color 150ms ease;
  }

  .search-open:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .search-open .kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 1px 5px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
  }

  /* dialog */
  .search-dialog {
    margin: 12vh auto auto;
    width: min(640px, 92vw);
    padding: 0;
    background: var(--bg-raise);
    border: 1px solid var(--border-bright);
    border-radius: var(--radius);
    color: var(--text);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .search-dialog::backdrop {
    background: rgba(9, 7, 22, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
  }

  #search-q {
    flex: 1;
    font: inherit;
    font-size: 1rem;
    color: var(--text);
    background: none;
    border: none;
    outline: none;
  }

  #search-q::placeholder {
    color: var(--text-muted);
  }

  .search-close {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 2px 6px;
    color: var(--text-muted);
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .search-close:hover {
    color: var(--cyan);
    border-color: var(--cyan);
  }

  .search-out {
    max-height: 60vh;
    overflow-y: auto;
    padding: var(--space-2);
  }

  /* Results are injected via innerHTML, so they never get Astro's scoped
     attribute — these rules must be :global to reach them. */
  .search-out :global(.search-hint) {
    padding: var(--space-5);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .search-out :global(.search-item) {
    display: grid;
    gap: 3px;
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--text);
  }

  /* divider between hits */
  .search-out :global(.search-item + .search-item) {
    border-top: 1px solid var(--border);
  }

  .search-out :global(.search-item:hover),
  .search-out :global(.search-item:focus-visible) {
    background: rgba(167, 139, 250, 0.12);
    outline: none;
  }

  .search-out :global(.search-kind) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cyan);
  }

  .search-out :global(.search-title) {
    font-weight: 600;
    font-size: 0.98rem;
    line-height: 1.3;
  }

  .search-out :global(.search-snip) {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-out :global(mark) {
    background: rgba(255, 79, 216, 0.25);
    color: var(--text);
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    .search-open .lbl,
    .search-open .kbd {
      display: none;
    }
  }
</style>
