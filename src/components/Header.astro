---
import Search from './Search.astro';

const nav = [
  { label: 'home', href: '/' },
  { label: 'docs', href: '/docs/web-recon' },
  { label: 'blog', href: '/blog' },
  { label: 'about', href: '/about' },
  { label: 'experience', href: '/experience' },
];

const path = Astro.url.pathname;
// '/' would match every path with startsWith, so match it exactly
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header>
  <div class="container bar">
    <a class="wordmark" href="/" data-text="LUDA HEX">
      <img src="/images/skull_script_kitty.svg" alt="" width="34" height="34" />
      <span>LUDA&nbsp;HEX</span>
    </a>

    <nav aria-label="Main">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <Search />

    <div class="social">
      <a href="https://github.com/nekosoft" aria-label="GitHub" title="GitHub">
        <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/salted-hash/"
        aria-label="LinkedIn"
        title="LinkedIn"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path
            d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0Z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(19, 16, 43, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    height: 64px;
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--text);
  }

  /* brief RGB-split glitch, hover only */
  .wordmark:hover span {
    animation: glitch 300ms steps(2, end) 1;
  }

  @keyframes glitch {
    0% {
      text-shadow:
        2px 0 var(--magenta),
        -2px 0 var(--cyan);
    }
    50% {
      text-shadow:
        -2px 0 var(--magenta),
        2px 0 var(--cyan);
    }
    100% {
      text-shadow: none;
    }
  }

  nav {
    margin-left: auto;
  }

  nav ul {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    padding: 0;
  }

  nav a {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  nav a:hover {
    color: var(--cyan);
  }

  nav a[aria-current='page'] {
    color: var(--magenta);
  }

  .social {
    display: flex;
    gap: var(--space-3);
  }

  .social a {
    color: var(--text-muted);
    display: flex;
    padding: var(--space-1);
  }

  .social a:hover {
    color: var(--cyan);
    filter: drop-shadow(0 0 6px rgba(83, 232, 244, 0.5));
  }

  @media (max-width: 640px) {
    .bar {
      gap: var(--space-3);
    }

    .wordmark span {
      display: none;
    }

    nav ul {
      gap: var(--space-4);
    }
  }

  /* on phones, drop the header social icons (still in the footer) and let
     the nav wrap to its own row below the brand so it never overflows */
  @media (max-width: 560px) {
    .social {
      display: none;
    }

    .bar {
      flex-wrap: wrap;
      height: auto;
      padding-block: var(--space-2);
      row-gap: var(--space-2);
      justify-content: space-between;
    }

    nav {
      order: 3;
      flex-basis: 100%;
      margin-left: 0;
    }

    nav ul {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-2) var(--space-5);
    }
  }
</style>
